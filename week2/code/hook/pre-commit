#!/usr/bin/env bash
# pre-commit hook · 校验 knowledge/raw/*.json 是否符合 schema
# 生成者: Week 2 · N5 · B 路 /opsx:apply
# 对应 spec: week2/specs/hook.md
#
# 安装: cp code/hook/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

SCHEMA="specs/schemas/collector-output.json"

# 获取 staged 的 knowledge/raw/*.json
FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "^knowledge/raw/.*\.json$" || true)

if [ -z "$FILES" ]; then
    exit 0  # 没 raw 改动 · 放行
fi

# schema 本身改了 · warn 不 reject
SCHEMA_CHANGED=$(git diff --cached --name-only | grep -E "^specs/schemas/.*\.json$" || true)
if [ -n "$SCHEMA_CHANGED" ]; then
    echo "⚠ schema 本身变更 · 跳过 raw 校验"
    exit 0
fi

# 并行校验 · 超时 3s
FAIL=0
for f in $FILES; do
    if ! timeout 0.5 jsonschema -i "$f" "$SCHEMA" 2>&1 | grep -q "."; then
        continue
    fi
    echo "✗ $f 不符合 schema · 详见:"
    jsonschema -i "$f" "$SCHEMA" || true
    FAIL=1
done

if [ $FAIL -eq 1 ]; then
    echo ""
    echo "pre-commit 拦截 · 按 specs/hook.md 要求 reject"
    echo "紧急跳过 · git commit --no-verify"
    exit 1
fi

exit 0
